{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "tsconfig": "tsconfig.json",
  "out": "dist-web/api",
  "name": "bireactive",
  "includeVersion": true,
  "hostedBaseUrl": "https://orionreed.github.io/bireactive/api/",
  "excludeInternal": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "hideGenerator": true,
  "categorizeByGroup": true,
  "groupOrder": [
    "Reactivity",
    "Values",
    "Lenses",
    "Animation",
    "Shapes",
    "Rendering",
    "Utilities",
    "*"
  ],
  "categoryOrder": ["Numeric", "Geometry", "Color", "Text", "Logic", "Collections", "Media", "*"],
  "navigationLinks": {
    "Demo": "https://orionreed.github.io/bireactive/"
  },
  "lightHighlightTheme": "github-light",
  "darkHighlightTheme": "github-dark",
  "customCss": "./theme/typedoc.css",
  "projectDocuments": ["guide/overview.md", "guide/getting-started.md"],
  "plugin": ["./theme/group-by-source.mjs", "@typhonjs-typedoc/typedoc-theme-dmt"],
  "theme": "default-modern",
  "dmtFavicon": "./public/favicon.svg",
  "dmtLinksService": {
    "GitHub": "https://github.com/OrionReed/bireactive",
    "NPM": "https://www.npmjs.com/package/bireactive"
  }
}

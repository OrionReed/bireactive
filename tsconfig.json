{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,
    "experimentalDecorators": true,

    /* JSX: the automatic runtime resolves to `src/jsx-runtime.ts` via the
     * `@bireactive/*` path alias. Only affects `.tsx` files. */
    "jsx": "react-jsx",
    "jsxImportSource": "@bireactive",

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Sub-package aliases — `@bireactive/core` etc. resolve to
     * `src/core/index.ts`, etc. Mirrored in vite.config.ts. */
    "paths": {
      "@bireactive": ["./src/index.ts"],
      "@bireactive/*": ["./src/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "site"],
  "exclude": ["dist", "node_modules"]
}

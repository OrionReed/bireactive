{
  "name": "bireactive",
  "version": "0.3.0",
  "description": "Bi-directional reactive programming.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host",
    "site": "vite build && typedoc && vitepress build docs",
    "docs": "typedoc && vitepress build docs",
    "docs:dev": "typedoc && vitepress dev docs --port 5556",
    "preview": "vite preview",
    "prebuild": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "test": "vitest --config vitest.config.ts run",
    "test:watch": "vitest --config vitest.config.ts",
    "bench": "node --expose-gc node_modules/.bin/vite-node",
    "typecheck": "tsc --noEmit --pretty",
    "fmt": "biome check --write .",
    "prepublishOnly": "npm test && npm run build",
    "release": "npm run release:patch",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "postversion": "npm publish && git push --follow-tags"
  },
  "dependencies": {
    "prism-esm": "^1.29.0-fix.6",
    "temml": "^0.13.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@preact/signals-core": "^1.14.2",
    "@types/node": "^22.0.0",
    "alien-signals": "^3.2.1",
    "fast-check": "^4.8.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "marked-footnote": "^1.4.0",
    "mitata": "^1.0.34",
    "reactive-framework-test-suite": "^0.0.2",
    "tsc-alias": "^1.8.17",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vite-node": "^5.3.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "bireactive",
    "reactive",
    "signals",
    "svg",
    "animation",
    "diagrams",
    "constraints",
    "propagators"
  ],
  "author": "Orion Reed",
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OrionReed/bireactive.git"
  },
  "homepage": "https://github.com/OrionReed/bireactive",
  "bugs": "https://github.com/OrionReed/bireactive/issues"
}
